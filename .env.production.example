# GraphMind Production Environment
# MVP Deployment - Billing Disabled
# Copy to .env.production and fill in your values

# ============= APPLICATION =============
APP_NAME=GraphMind
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ============= DATABASE - PostgreSQL =============
POSTGRES_USER=graphmind_prod
POSTGRES_PASSWORD=<STRONG_PASSWORD_HERE>
POSTGRES_HOST=<YOUR_DB_HOST>
POSTGRES_PORT=5432
POSTGRES_DB=graphmind_prod
POSTGRES_ECHO=False
POSTGRES_POOL_SIZE=20
POSTGRES_POOL_RECYCLE=3600
POSTGRES_MAX_OVERFLOW=40

# ============= GRAPH DATABASE - Neo4j =============
NEO4J_URI=bolt://<YOUR_NEO4J_HOST>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<NEO4J_PASSWORD>
NEO4J_POOL_SIZE=20
NEO4J_MAX_CONNECTION_LIFETIME=3600

# ============= JWT / SECURITY =============
JWT_SECRET_KEY=<GENERATE_SECURE_KEY_min_32_chars>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============= ENCRYPTION =============
ENCRYPTION_ALGORITHM=fernet
# Per-tenant encryption keys (one per tenant)
# Format: TENANT_<tenant_id>_ENCRYPTION_KEY=<fernet_key>
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ============= EMBEDDINGS =============
EMBEDDING_DIMENSION=768
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============= LLM - DeepInfra =============
DEEPINFRA_API_KEY=<YOUR_DEEPINFRA_API_KEY>
DEEPINFRA_API_URL=https://api.deepinfra.com/v1/openai

# ============= LOGGING =============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============= FEATURE FLAGS =============
USE_REAL_EMBEDDINGS=False
USE_LLM_ENTITY_EXTRACTION=False
ENABLE_BILLING=False  # 🔥 MVP: Billing disabled

# ============= RATE LIMITING =============
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ============= CORS =============
# ⚠️ CRITICAL: Set specific origins in production (not "*")
CORS_ORIGINS=["https://yourdomain.com"]
CORS_CREDENTIALS=True
CORS_METHODS=["GET", "POST", "PUT", "DELETE"]
CORS_HEADERS=["*"]

# ============= DEPLOYMENT NOTES =============
# 1. Generate secure secrets:
#    JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    POSTGRES_PASSWORD: Use strong random password (32+ chars, mixed case, numbers, symbols)
#
# 2. Database setup:
#    - PostgreSQL: Create database and user
#    - Neo4j: Create graph database and set password
#    - Run migrations: alembic upgrade head
#
# 3. Before deploying:
#    - Test all connections locally
#    - Run test suite
#    - Verify all environment variables are set
#    - Check SSL certificates are valid
#
# 4. Post-deployment:
#    - Check /health endpoint
#    - Monitor logs in real-time
#    - Test API with sample queries
#    - Enable billing: change ENABLE_BILLING=True when ready
